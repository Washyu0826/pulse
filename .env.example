# Database
# 注意：host 埠是 5433（docker-compose 已避開本機 PostgreSQL 常佔的 5432）。
# 用 127.0.0.1 而非 localhost，避免 Windows 上 localhost 先解析成 IPv6 的問題。
DATABASE_URL=postgresql+asyncpg://pulse:pulse@127.0.0.1:5433/pulse
DATABASE_URL_SYNC=postgresql://pulse:pulse@127.0.0.1:5433/pulse  # for Alembic

# Reddit API
# 申請: https://www.reddit.com/prefs/apps  (選 'script' 類型)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=pulse/0.1 by your_reddit_username

# Threads 爬蟲 cookie（Threads = Pulse 主力來源；Selenium 注入越過登入牆）
# 登入 threads.com（建議用次要帳號）→ F12 DevTools → Application → Cookies →
# https://www.threads.com → 複製 sessionid 的 Value 貼這。缺則退化為未登入（資料很少）。
THREADS_SESSIONID=

# Facebook 爬蟲 cookie（crawl_facebook.py；台灣 AI 社團/專頁繁中訊號）
# ⚠️ 強烈建議用次要帳號 —— FB 對自動化偵測極嚴，主帳號有被 checkpoint/封鎖風險。
# 登入 facebook.com → F12 → Application → Cookies → https://www.facebook.com →
# 複製 c_user 與 xs 兩個 cookie 的 Value 分別貼這。兩者都要，缺一不可。
FB_C_USER=
FB_XS=

# 每日電子報（send_newsletter.py，Gmail SMTP，全免費/地端）
# Gmail 需開兩步驟驗證後產「應用程式密碼」：https://myaccount.google.com/apppasswords
PULSE_SMTP_USER=your_gmail@gmail.com
PULSE_SMTP_APP_PASSWORD=
PULSE_NEWSLETTER_TO=your_gmail@gmail.com
# 可選覆寫：PULSE_SMTP_HOST / PULSE_SMTP_PORT / PULSE_SUMMARY_MODEL / PULSE_COVER_MODEL

# Anthropic API
# 申請: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# 可選：Notification
RESEND_API_KEY=
SLACK_WEBHOOK_URL=

# 可選：MLflow
MLFLOW_TRACKING_URI=http://localhost:5000

# ===== Airflow（docker-compose）—— 必填，請自行產生，切勿沿用任何範例值 =====
# WEBSERVER_SECRET_KEY：Flask session 簽章金鑰。缺值時 compose 會啟動即報錯（fail fast）。
#   MUST generate your own，例如：
#     python -c "import secrets; print(secrets.token_hex(32))"
AIRFLOW_WEBSERVER_SECRET_KEY=
# FERNET_KEY：加密 Airflow connection/variable。本機可留空（退化＋警告）；prod MUST 設定。
#   MUST generate your own，例如：
#     python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW_FERNET_KEY=
# Airflow Web UI 初始管理員帳密 —— 缺值時 compose 會啟動即報錯。請自訂，勿用 admin:admin。
AIRFLOW_ADMIN_USER=
AIRFLOW_ADMIN_PASSWORD=

# ===== Grafana（docker-compose）—— 不填則退化為 admin/admin（僅限本機）=====
# 對外/類 prod 部署 MUST 自行設定一組強密碼。
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=

# App
ENVIRONMENT=development
LOG_LEVEL=INFO

# ===== 容器化部署（docker-compose 的 api / web 服務）=====
# api 容器內用 DATABASE_URL=...@db:5432/pulse（compose 已內建，不必在此設）。
# web 容器內以 API_URL_INTERNAL=http://api:8000 走內網打 API（compose 已內建）。
# 下面僅是瀏覽器端（client fetch）會用到的對外 API 位址；類 prod 部署改成你的對外網域。
NEXT_PUBLIC_API_URL=http://localhost:8010
