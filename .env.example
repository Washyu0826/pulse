# Database
# 注意：host 埠是 5433（docker-compose 已避開本機 PostgreSQL 常佔的 5432）。
# 用 127.0.0.1 而非 localhost，避免 Windows 上 localhost 先解析成 IPv6 的問題。
DATABASE_URL=postgresql+asyncpg://pulse:pulse@127.0.0.1:5433/pulse
DATABASE_URL_SYNC=postgresql://pulse:pulse@127.0.0.1:5433/pulse  # for Alembic

# Reddit API
# 申請: https://www.reddit.com/prefs/apps  (選 'script' 類型)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=pulse/0.1 by your_reddit_username

# Anthropic API
# 申請: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# 可選：Notification
RESEND_API_KEY=
SLACK_WEBHOOK_URL=

# 可選：MLflow
MLFLOW_TRACKING_URI=http://localhost:5000

# App
ENVIRONMENT=development
LOG_LEVEL=INFO
