# Database
# 注意：host 埠是 5433（docker-compose 已避開本機 PostgreSQL 常佔的 5432）。
# 用 127.0.0.1 而非 localhost，避免 Windows 上 localhost 先解析成 IPv6 的問題。
DATABASE_URL=postgresql+asyncpg://pulse:pulse@127.0.0.1:5433/pulse
DATABASE_URL_SYNC=postgresql://pulse:pulse@127.0.0.1:5433/pulse  # for Alembic

# Reddit API
# 申請: https://www.reddit.com/prefs/apps  (選 'script' 類型)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=pulse/0.1 by your_reddit_username

# Threads 爬蟲 cookie（Threads = Pulse 主力來源；Selenium 注入越過登入牆）
# 登入 threads.com（建議用次要帳號）→ F12 DevTools → Application → Cookies →
# https://www.threads.com → 複製 sessionid 的 Value 貼這。缺則退化為未登入（資料很少）。
THREADS_SESSIONID=

# Facebook 爬蟲 cookie（crawl_facebook.py；台灣 AI 社團/專頁繁中訊號）
# ⚠️ 強烈建議用次要帳號 —— FB 對自動化偵測極嚴，主帳號有被 checkpoint/封鎖風險。
# 登入 facebook.com → F12 → Application → Cookies → https://www.facebook.com →
# 複製 c_user 與 xs 兩個 cookie 的 Value 分別貼這。兩者都要，缺一不可。
FB_C_USER=
FB_XS=

# 每日電子報（send_newsletter.py，Gmail SMTP，全免費/地端）
# Gmail 需開兩步驟驗證後產「應用程式密碼」：https://myaccount.google.com/apppasswords
PULSE_SMTP_USER=your_gmail@gmail.com
PULSE_SMTP_APP_PASSWORD=
PULSE_NEWSLETTER_TO=your_gmail@gmail.com
# 可選覆寫：PULSE_SMTP_HOST / PULSE_SMTP_PORT / PULSE_SUMMARY_MODEL / PULSE_COVER_MODEL

# Anthropic API
# 申請: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# 可選：Notification
RESEND_API_KEY=
SLACK_WEBHOOK_URL=

# 可選：MLflow
MLFLOW_TRACKING_URI=http://localhost:5000

# App
ENVIRONMENT=development
LOG_LEVEL=INFO
